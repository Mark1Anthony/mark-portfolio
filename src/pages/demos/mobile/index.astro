  <style>
    /* ═══════════════════════════════════════════════
       iPhone-accurate phone shell.
       Frame: 360 x 780 (9:19.5, ~iPhone 14 Pro @ 91% scale)
       Inner screen: 332 x 752
       Status bar safe area: 50px
       Bottom safe area: 30px
       All content uses proportional iOS sizes.
    ═══════════════════════════════════════════════ */
    .phone-shell {
      position: relative;
      width: 360px;
      height: 780px;
      background: #000;
      border-radius: 54px;
      border: 14px solid #000;
      box-shadow: 0 50px 100px rgba(0, 0, 0, 0.5), 0 0 0 2px #2a2a2a;
      overflow: hidden;
    }
    .phone-shell .island {
      position: absolute;
      top: 11px;
      left: 50%;
      transform: translateX(-50%);
      width: 110px;
      height: 30px;
      background: #000;
      border-radius: 100px;
      z-index: 50;
    }
    .phone-shell .status-bar {
      position: absolute;
      top: 0;
      inset-inline: 0;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 30px 0 36px;
      z-index: 40;
      color: white;
      pointer-events: none;
    }
    .status-time {
      font-size: 15px;
      font-weight: 600;
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      letter-spacing: -0.3px;
    }
    .status-icons {
      display: flex;
      align-items: center;
      gap: 5px;
    }

    /* Screen wrapper */
    #screen-wrap {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }

    /* Each screen fills the inner area with iOS-accurate safe-area padding */
    .screen {
      position: absolute;
      inset: 0;
      overflow-y: auto;
      overflow-x: hidden;
      padding: 56px 20px 34px;   /* status bar · sides · home indicator */
      box-sizing: border-box;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", sans-serif;
      -webkit-font-smoothing: antialiased;
      scrollbar-width: none;
    }
    .screen::-webkit-scrollbar { display: none; }

    /* All direct children of a screen fill the full available width */
    .screen > * {
      width: 100%;
      box-sizing: border-box;
    }

    /* iOS-accurate typography helpers */
    .ios-title  { font-size: 34px; font-weight: 700; letter-spacing: -0.5px; line-height: 1.1; }
    .ios-title2 { font-size: 22px; font-weight: 700; letter-spacing: -0.3px; line-height: 1.15; }
    .ios-h      { font-size: 17px; font-weight: 600; letter-spacing: -0.2px; }
    .ios-body   { font-size: 15px; font-weight: 400; line-height: 1.4; }
    .ios-sub    { font-size: 13px; font-weight: 400; line-height: 1.3; }
    .ios-cap    { font-size: 11px; font-weight: 500; letter-spacing: 0.4px; text-transform: uppercase; }

    .ios-btn {
      display: block;
      width: 100%;
      height: 50px;
      border-radius: 14px;
      font-size: 17px;
      font-weight: 600;
      letter-spacing: -0.2px;
      border: none;
      cursor: pointer;
      transition: transform 0.1s ease, opacity 0.1s ease;
    }
    .ios-btn:active { transform: scale(0.98); opacity: 0.85; }

    .home-indicator {
      position: absolute;
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 110px;
      height: 4px;
      background: rgba(255, 255, 255, 0.35);
      border-radius: 2px;
      z-index: 50;
      pointer-events: none;
    }
  </style>

  <script>
    const screens = document.querySelectorAll<HTMLElement>('.screen');
    const gotoButtons = document.querySelectorAll<HTMLElement>('.goto-btn, .screen-link');

    function showScreen(name: string) {
      screens.forEach((s) => {
        s.style.display = s.dataset.screen === name ? 'flex' : 'none';
      });
      document.querySelectorAll<HTMLElement>('.screen-link').forEach((link) => {
        const active = link.dataset.goto === name;
        link.classList.toggle('bg-ink-800/40', active);
        link.classList.toggle('ring-1', active);
        link.classList.toggle('ring-accent-cyan/30', active);
      });
    }

    gotoButtons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = (btn as HTMLElement).dataset.goto;
        if (target) {
          e.stopPropagation();
          showScreen(target);
          const wrap = document.getElementById('screen-wrap');
          if (wrap) wrap.scrollTop = 0;
        }
      });
    });
  </script>
</Layout>
