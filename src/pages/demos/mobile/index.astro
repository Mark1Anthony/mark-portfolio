---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Mobile App Prototype — Demo" description="Clickable mobile app prototype — navigate through the screens like a real app.">

  <a href="/#work" class="fixed top-6 left-6 z-40 inline-flex items-center gap-2 px-4 py-2 rounded-full backdrop-blur-md bg-black/40 border border-white/10 text-sm text-ink-200 hover:text-accent-cyan hover:border-accent-cyan/40 transition">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to portfolio
  </a>

  <div class="min-h-screen py-16 px-4 flex items-center">
    <div class="max-w-5xl mx-auto w-full">
      <div class="mb-10 text-center">
        <h1 class="font-display font-bold text-4xl md:text-5xl mb-3">Mobile App <span class="text-gradient">— Prototype</span></h1>
        <p class="text-ink-400 text-sm max-w-xl mx-auto">
          A clickable prototype for a fictional fitness-tracker app called <strong class="text-ink-200">Pulse</strong>.
          Tap through the screens like a real app. Everything runs in the browser — no build, no install.
        </p>
      </div>

      <div class="flex flex-col lg:grid lg:grid-cols-[1fr_auto_1fr] gap-8 items-center justify-items-center">
        <!-- Left panel: info -->
        <div class="hidden lg:block justify-self-end max-w-[280px]">
          <div class="glass rounded-2xl p-6">
            <div class="text-accent-cyan font-mono text-[10px] uppercase tracking-widest mb-3">Screens</div>
            <div class="space-y-2 text-sm">
              <div class="screen-link flex items-center gap-3 p-2 rounded cursor-pointer hover:bg-ink-800/40 transition" data-goto="onboarding">
                <div class="w-8 h-8 rounded bg-gradient-to-br from-accent-cyan to-accent-teal flex items-center justify-center text-ink-950 text-xs font-bold">1</div>
                <div>
                  <div class="text-ink-100 font-semibold">Onboarding</div>
                  <div class="text-ink-500 text-xs">Welcome splash + intro</div>
                </div>
              </div>
              <div class="screen-link flex items-center gap-3 p-2 rounded cursor-pointer hover:bg-ink-800/40 transition" data-goto="home">
                <div class="w-8 h-8 rounded bg-gradient-to-br from-accent-cyan to-accent-teal flex items-center justify-center text-ink-950 text-xs font-bold">2</div>
                <div>
                  <div class="text-ink-100 font-semibold">Home</div>
                  <div class="text-ink-500 text-xs">Dashboard with rings</div>
                </div>
              </div>
              <div class="screen-link flex items-center gap-3 p-2 rounded cursor-pointer hover:bg-ink-800/40 transition" data-goto="workout">
                <div class="w-8 h-8 rounded bg-gradient-to-br from-accent-cyan to-accent-teal flex items-center justify-center text-ink-950 text-xs font-bold">3</div>
                <div>
                  <div class="text-ink-100 font-semibold">Workout</div>
                  <div class="text-ink-500 text-xs">Live session view</div>
                </div>
              </div>
              <div class="screen-link flex items-center gap-3 p-2 rounded cursor-pointer hover:bg-ink-800/40 transition" data-goto="stats">
                <div class="w-8 h-8 rounded bg-gradient-to-br from-accent-cyan to-accent-teal flex items-center justify-center text-ink-950 text-xs font-bold">4</div>
                <div>
                  <div class="text-ink-100 font-semibold">Stats</div>
                  <div class="text-ink-500 text-xs">Weekly breakdown</div>
                </div>
              </div>
              <div class="screen-link flex items-center gap-3 p-2 rounded cursor-pointer hover:bg-ink-800/40 transition" data-goto="profile">
                <div class="w-8 h-8 rounded bg-gradient-to-br from-accent-cyan to-accent-teal flex items-center justify-center text-ink-950 text-xs font-bold">5</div>
                <div>
                  <div class="text-ink-100 font-semibold">Profile</div>
                  <div class="text-ink-500 text-xs">Account & settings</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Phone frame — real iPhone 14 Pro ratio (9:19.5 ~ 393x852 scaled to 360x780) -->
        <!-- Inner screen: 332x752, matches iOS safe areas proportionally -->
        <div class="flex justify-center justify-self-center">
          <div class="phone-shell">
            <!-- Dynamic Island -->
            <div class="island"></div>

            <!-- Status bar — positioned in iOS safe area above screen content -->
            <div class="status-bar">
              <span class="status-time">9:41</span>
              <div class="status-icons">
                <svg width="16" height="10" fill="currentColor" viewBox="0 0 16 10"><rect x="0" y="6" width="2" height="4" rx="0.5"/><rect x="3" y="4" width="2" height="6" rx="0.5"/><rect x="6" y="2" width="2" height="8" rx="0.5"/><rect x="9" y="0" width="2" height="10" rx="0.5"/></svg>
                <svg width="14" height="10" fill="currentColor" viewBox="0 0 14 10"><path d="M7 0C4 0 1.5 1.2 0 2.8l1.4 1.4C2.8 2.8 4.8 2 7 2s4.2.8 5.6 2.2L14 2.8C12.5 1.2 10 0 7 0zm0 3C5 3 3.3 3.8 2.2 5l1.4 1.4C4.5 5.5 5.7 5 7 5s2.5.5 3.4 1.4L11.8 5C10.7 3.8 9 3 7 3zm0 3c-.7 0-1.4.3-1.9.8L7 8.3l1.9-1.5C8.4 6.3 7.7 6 7 6z"/></svg>
                <svg width="22" height="10" viewBox="0 0 22 10" fill="none"><rect x="0.5" y="0.5" width="17" height="9" rx="2" stroke="white" stroke-opacity="0.6"/><rect x="2" y="2" width="14" height="6" rx="1" fill="white"/><rect x="18.5" y="3.5" width="1.5" height="3" rx="0.5" fill="white" fill-opacity="0.6"/></svg>
              </div>
            </div>

            <!-- Screen container -->
            <div id="screen-wrap">

              <!-- ─── ONBOARDING ─── -->
              <div class="screen" data-screen="onboarding" style="background: linear-gradient(180deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%); color: white; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <div style="display: flex; flex-direction: column; align-items: center; width: 100%;">
                  <!-- App icon -->
                  <div style="width: 88px; height: 88px; border-radius: 22px; background: linear-gradient(135deg, #22d3ee, #a78bfa); display: flex; align-items: center; justify-content: center; margin-bottom: 28px; box-shadow: 0 20px 60px rgba(34, 211, 238, 0.3);">
                    <svg width="44" height="44" fill="none" stroke="white" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                  </div>
                  <div class="ios-title" style="text-align: center; margin-bottom: 10px;">Welcome to Pulse</div>
                  <p class="ios-body" style="text-align: center; color: rgba(255,255,255,0.6); margin-bottom: 40px; max-width: 260px;">
                    Your daily fitness tracker.<br>Simple rings. Real data.
                  </p>
                  <!-- Page dots -->
                  <div style="display: flex; gap: 6px; margin-bottom: 32px;">
                    <div style="width: 22px; height: 6px; border-radius: 3px; background: #22d3ee;"></div>
                    <div style="width: 6px; height: 6px; border-radius: 3px; background: rgba(255,255,255,0.25);"></div>
                    <div style="width: 6px; height: 6px; border-radius: 3px; background: rgba(255,255,255,0.25);"></div>
                  </div>
                  <!-- CTA -->
                  <button class="ios-btn goto-btn" data-goto="home" style="background: linear-gradient(135deg, #22d3ee, #0891b2); color: #0f172a; box-shadow: 0 10px 40px rgba(34, 211, 238, 0.35); margin-bottom: 14px;">Get started</button>
                  <button class="goto-btn" data-goto="home" style="background: none; border: none; color: rgba(255,255,255,0.55); font-size: 15px; padding: 10px; cursor: pointer;">I already have an account</button>
                </div>
              </div>

              <!-- ─── HOME ─── -->
              <div class="screen" data-screen="home" style="background: #0f172a; color: white; display: none;">
                <div>
                  <!-- Header -->
                  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px;">
                    <div>
                      <div class="ios-sub" style="color: rgba(255,255,255,0.55);">Tuesday, April 11</div>
                      <div class="ios-title2" style="margin-top: 2px;">Good morning, Mark</div>
                    </div>
                    <div class="goto-btn" data-goto="profile" style="width: 38px; height: 38px; border-radius: 19px; background: linear-gradient(135deg, #22d3ee, #a78bfa); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 15px; cursor: pointer; flex-shrink: 0;">M</div>
                  </div>

                  <!-- Rings card -->
                  <div style="background: linear-gradient(180deg, rgba(30, 41, 59, 0.6), rgba(15, 23, 42, 0.8)); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 20px; padding: 22px 20px; margin-bottom: 14px;">
                    <div style="position: relative; width: 150px; height: 150px; margin: 0 auto;">
                      <svg viewBox="0 0 200 200" style="width: 100%; height: 100%; transform: rotate(-90deg);">
                        <circle cx="100" cy="100" r="85" stroke="rgba(34, 211, 238, 0.1)" stroke-width="14" fill="none"/>
                        <circle cx="100" cy="100" r="85" stroke="#22d3ee" stroke-width="14" fill="none" stroke-linecap="round" stroke-dasharray="534" stroke-dashoffset="107"/>
                        <circle cx="100" cy="100" r="65" stroke="rgba(244, 114, 182, 0.1)" stroke-width="14" fill="none"/>
                        <circle cx="100" cy="100" r="65" stroke="#f472b6" stroke-width="14" fill="none" stroke-linecap="round" stroke-dasharray="408" stroke-dashoffset="82"/>
                        <circle cx="100" cy="100" r="45" stroke="rgba(134, 239, 172, 0.1)" stroke-width="14" fill="none"/>
                        <circle cx="100" cy="100" r="45" stroke="#86efac" stroke-width="14" fill="none" stroke-linecap="round" stroke-dasharray="283" stroke-dashoffset="42"/>
                      </svg>
                      <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; flex-direction: column;">
                        <div style="font-size: 28px; font-weight: 700; letter-spacing: -0.5px;">80%</div>
                        <div class="ios-cap" style="color: rgba(255,255,255,0.5); margin-top: 2px;">Daily goal</div>
                      </div>
                    </div>

                    <!-- Stats row -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 18px;">
                      <div style="text-align: center;">
                        <div style="width: 6px; height: 6px; border-radius: 50%; background: #22d3ee; margin: 0 auto 4px;"></div>
                        <div class="ios-cap" style="color: rgba(255,255,255,0.5); font-size: 10px;">Move</div>
                        <div style="font-size: 14px; font-weight: 600; margin-top: 2px;">420 kcal</div>
                      </div>
                      <div style="text-align: center;">
                        <div style="width: 6px; height: 6px; border-radius: 50%; background: #f472b6; margin: 0 auto 4px;"></div>
                        <div class="ios-cap" style="color: rgba(255,255,255,0.5); font-size: 10px;">Exercise</div>
                        <div style="font-size: 14px; font-weight: 600; margin-top: 2px;">32 min</div>
                      </div>
                      <div style="text-align: center;">
                        <div style="width: 6px; height: 6px; border-radius: 50%; background: #86efac; margin: 0 auto 4px;"></div>
                        <div class="ios-cap" style="color: rgba(255,255,255,0.5); font-size: 10px;">Stand</div>
                        <div style="font-size: 14px; font-weight: 600; margin-top: 2px;">10 / 12</div>
                      </div>
                    </div>
                  </div>

                  <!-- Action buttons -->
                  <button class="ios-btn goto-btn" data-goto="workout" style="background: linear-gradient(135deg, #22d3ee, #0891b2); color: #0f172a; margin-bottom: 10px;">Start workout</button>
                  <button class="ios-btn goto-btn" data-goto="stats" style="background: rgba(255, 255, 255, 0.08); color: white; border: 1px solid rgba(255, 255, 255, 0.1);">View stats</button>
                </div>
              </div>

              <!-- ─── WORKOUT ─── -->
              <div class="screen" data-screen="workout" style="background: linear-gradient(180deg, #1e1b4b 0%, #0f172a 100%); color: white; display: none;">
                <div style="height: 100%; display: flex; flex-direction: column;">
                  <!-- Nav -->
                  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                    <button class="goto-btn" data-goto="home" style="background: none; border: none; color: rgba(255,255,255,0.7); font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 3px; padding: 0;">
                      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                      Home
                    </button>
                    <div style="display: flex; align-items: center; gap: 6px;">
                      <div style="width: 6px; height: 6px; border-radius: 50%; background: #ef4444; animation: pulse 1.5s ease-in-out infinite;"></div>
                      <div class="ios-cap" style="color: #ef4444; font-size: 10px;">LIVE</div>
                    </div>
                  </div>

                  <!-- Content centered -->
                  <div style="flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;">
                    <div class="ios-cap" style="color: rgba(255,255,255,0.5); margin-bottom: 8px;">Running · Outdoor</div>
                    <div style="font-size: 56px; font-weight: 700; line-height: 1; font-variant-numeric: tabular-nums; letter-spacing: -1px; margin-bottom: 20px;">28:34</div>

                    <!-- Stat trio -->
                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; width: 100%; margin-bottom: 20px;">
                      <div style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 12px 8px;">
                        <div class="ios-cap" style="color: rgba(255,255,255,0.45); font-size: 9px;">Distance</div>
                        <div style="font-size: 16px; font-weight: 700; margin-top: 4px;">4.2 km</div>
                      </div>
                      <div style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 12px 8px;">
                        <div class="ios-cap" style="color: rgba(255,255,255,0.45); font-size: 9px;">Pace</div>
                        <div style="font-size: 16px; font-weight: 700; margin-top: 4px;">6'48"</div>
                      </div>
                      <div style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 12px 8px;">
                        <div class="ios-cap" style="color: rgba(255,255,255,0.45); font-size: 9px;">HR</div>
                        <div style="font-size: 16px; font-weight: 700; margin-top: 4px; color: #ef4444;">142</div>
                      </div>
                    </div>
                  </div>

                  <!-- Action -->
                  <button class="ios-btn goto-btn" data-goto="stats" style="background: #ef4444; color: white; margin-bottom: 6px;">Finish workout</button>
                </div>
              </div>

              <!-- ─── STATS ─── -->
              <div class="screen" data-screen="stats" style="background: #0f172a; color: white; display: none;">
                <div>
                  <!-- Nav -->
                  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px;">
                    <button class="goto-btn" data-goto="home" style="background: none; border: none; color: rgba(255,255,255,0.7); font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 3px; padding: 0;">
                      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                      Home
                    </button>
                    <div class="ios-h">This week</div>
                    <div style="width: 50px;"></div>
                  </div>

                  <!-- Streak banner -->
                  <div style="background: linear-gradient(135deg, rgba(34, 211, 238, 0.15), rgba(168, 139, 250, 0.15)); border: 1px solid rgba(34, 211, 238, 0.25); border-radius: 16px; padding: 16px; margin-bottom: 18px;">
                    <div class="ios-cap" style="color: #22d3ee; font-size: 10px;">Streak</div>
                    <div style="font-size: 28px; font-weight: 700; letter-spacing: -0.5px; margin-top: 2px;">12 days</div>
                    <div class="ios-sub" style="color: rgba(255,255,255,0.55); margin-top: 2px;">Keep it going!</div>
                  </div>

                  <!-- Chart -->
                  <div class="ios-cap" style="color: rgba(255,255,255,0.5); margin-bottom: 12px; font-size: 10px;">Calories burned</div>
                  <div style="display: flex; align-items: flex-end; justify-content: space-between; gap: 6px; height: 110px; margin-bottom: 18px; padding: 0 4px;">
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%;">
                      <div style="width: 100%; background: linear-gradient(180deg, #22d3ee, #0891b2); border-radius: 4px 4px 0 0; flex: 0 0 60%;"></div>
                      <div style="font-size: 10px; color: rgba(255,255,255,0.5); flex-shrink: 0;">M</div>
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%;">
                      <div style="width: 100%; background: linear-gradient(180deg, #22d3ee, #0891b2); border-radius: 4px 4px 0 0; flex: 0 0 80%;"></div>
                      <div style="font-size: 10px; color: rgba(255,255,255,0.5); flex-shrink: 0;">T</div>
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%;">
                      <div style="width: 100%; background: linear-gradient(180deg, #22d3ee, #0891b2); border-radius: 4px 4px 0 0; flex: 0 0 45%;"></div>
                      <div style="font-size: 10px; color: rgba(255,255,255,0.5); flex-shrink: 0;">W</div>
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%;">
                      <div style="width: 100%; background: linear-gradient(180deg, #22d3ee, #0891b2); border-radius: 4px 4px 0 0; flex: 0 0 95%;"></div>
                      <div style="font-size: 10px; color: rgba(255,255,255,0.5); flex-shrink: 0;">T</div>
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%;">
                      <div style="width: 100%; background: linear-gradient(180deg, #22d3ee, #0891b2); border-radius: 4px 4px 0 0; flex: 0 0 70%;"></div>
                      <div style="font-size: 10px; color: rgba(255,255,255,0.5); flex-shrink: 0;">F</div>
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%;">
                      <div style="width: 100%; background: linear-gradient(180deg, #22d3ee, #0891b2); border-radius: 4px 4px 0 0; flex: 0 0 100%;"></div>
                      <div style="font-size: 10px; color: #22d3ee; font-weight: 700; flex-shrink: 0;">S</div>
                    </div>
                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%;">
                      <div style="width: 100%; background: rgba(255,255,255,0.1); border: 1px dashed rgba(255,255,255,0.2); border-radius: 4px 4px 0 0; flex: 0 0 50%;"></div>
                      <div style="font-size: 10px; color: rgba(255,255,255,0.35); flex-shrink: 0;">S</div>
                    </div>
                  </div>

                  <!-- Summary cards -->
                  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 18px;">
                    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 12px 14px;">
                      <div class="ios-cap" style="color: rgba(255,255,255,0.45); font-size: 10px;">Total</div>
                      <div style="font-size: 19px; font-weight: 700; margin-top: 3px;">2,840 kcal</div>
                    </div>
                    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 12px 14px;">
                      <div class="ios-cap" style="color: rgba(255,255,255,0.45); font-size: 10px;">Avg pace</div>
                      <div style="font-size: 19px; font-weight: 700; margin-top: 3px;">6'12"</div>
                    </div>
                  </div>

                  <button class="ios-btn goto-btn" data-goto="home" style="background: rgba(255,255,255,0.08); color: white; border: 1px solid rgba(255,255,255,0.1);">Back to home</button>
                </div>
              </div>

              <!-- ─── PROFILE ─── -->
              <div class="screen" data-screen="profile" style="background: #0f172a; color: white; display: none;">
                <div>
                  <!-- Nav -->
                  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
                    <button class="goto-btn" data-goto="home" style="background: none; border: none; color: rgba(255,255,255,0.7); font-size: 15px; cursor: pointer; display: flex; align-items: center; gap: 3px; padding: 0;">
                      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                      Home
                    </button>
                    <div class="ios-h">Profile</div>
                    <div style="width: 50px;"></div>
                  </div>

                  <!-- Avatar + name -->
                  <div style="text-align: center; margin-bottom: 24px;">
                    <div style="width: 80px; height: 80px; margin: 0 auto 10px; border-radius: 40px; background: linear-gradient(135deg, #22d3ee, #a78bfa); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 28px;">M</div>
                    <div class="ios-h" style="font-size: 18px;">Mark Amaechi</div>
                    <div class="ios-sub" style="color: rgba(255,255,255,0.45); margin-top: 2px;">Member since 2024</div>
                  </div>

                  <!-- Stats grid -->
                  <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 14px; margin-bottom: 20px; display: grid; grid-template-columns: 1fr 1fr 1fr;">
                    <div style="text-align: center;">
                      <div style="font-size: 20px; font-weight: 700;">127</div>
                      <div class="ios-cap" style="color: rgba(255,255,255,0.5); font-size: 10px; margin-top: 2px;">Workouts</div>
                    </div>
                    <div style="text-align: center; border-left: 1px solid rgba(255,255,255,0.08); border-right: 1px solid rgba(255,255,255,0.08);">
                      <div style="font-size: 20px; font-weight: 700;">542</div>
                      <div class="ios-cap" style="color: rgba(255,255,255,0.5); font-size: 10px; margin-top: 2px;">km total</div>
                    </div>
                    <div style="text-align: center;">
                      <div style="font-size: 20px; font-weight: 700;">12</div>
                      <div class="ios-cap" style="color: rgba(255,255,255,0.5); font-size: 10px; margin-top: 2px;">Streak</div>
                    </div>
                  </div>

                  <!-- Settings list -->
                  <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 14px; overflow: hidden;">
                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px 16px; border-bottom: 1px solid rgba(255,255,255,0.05);">
