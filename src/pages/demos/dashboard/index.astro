---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="DealFlow CRM — Live Demo" description="Full-stack CRM with auth, Kanban pipeline, contacts and activities. Built with Next.js 15 + Supabase.">

  <a href="/mark-portfolio/#work" class="fixed top-6 left-6 z-40 inline-flex items-center gap-2 px-4 py-2 rounded-full backdrop-blur-md bg-black/40 border border-white/10 text-sm text-ink-200 hover:text-accent-cyan hover:border-accent-cyan/40 transition">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to portfolio
  </a>

  <div class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="max-w-lg text-center">

      <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-white font-bold text-2xl mb-6">D</div>

      <h1 class="font-display font-bold text-3xl md:text-4xl text-ink-50 mb-4">DealFlow CRM</h1>

      <p class="text-ink-400 text-base leading-relaxed mb-8">
        A full-stack CRM with real authentication, PostgreSQL database with Row Level Security,
        drag-and-drop Kanban pipeline, contact management and activity tracking.
        Built with Next.js 15, Supabase and TypeScript.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-10">
        <a href="https://dealflow-crm-eta.vercel.app" target="_blank" rel="noopener" class="btn-primary text-sm py-3 px-6 inline-flex items-center justify-center gap-2">
          Open live app
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
        </a>
        <a href="https://github.com/Mark1Anthony/dealflow-crm" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 text-ink-400 text-sm font-medium hover:text-accent-cyan transition py-3 px-6 border border-white/10 rounded-full hover:border-accent-cyan/30">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          View source
        </a>
      </div>

      <div class="glass rounded-2xl p-6 text-left">
        <div class="text-ink-500 font-mono text-[10px] uppercase tracking-widest mb-4">How to try it</div>
        <ol class="space-y-3 text-sm text-ink-300">
          <li class="flex gap-3">
            <span class="w-6 h-6 rounded-lg bg-cyan-500/15 text-cyan-400 flex items-center justify-center text-xs font-bold flex-shrink-0">1</span>
            <span>Click <strong class="text-ink-100">Open live app</strong> above</span>
          </li>
          <li class="flex gap-3">
            <span class="w-6 h-6 rounded-lg bg-cyan-500/15 text-cyan-400 flex items-center justify-center text-xs font-bold flex-shrink-0">2</span>
            <span>Sign up with any email and password (no confirmation needed)</span>
          </li>
          <li class="flex gap-3">
            <span class="w-6 h-6 rounded-lg bg-cyan-500/15 text-cyan-400 flex items-center justify-center text-xs font-bold flex-shrink-0">3</span>
            <span>Click <strong class="text-ink-100">Load demo data</strong> to populate the app</span>
          </li>
          <li class="flex gap-3">
            <span class="w-6 h-6 rounded-lg bg-cyan-500/15 text-cyan-400 flex items-center justify-center text-xs font-bold flex-shrink-0">4</span>
            <span>Try dragging deals between pipeline stages, creating contacts, logging activities</span>
          </li>
        </ol>
      </div>

      <div class="mt-8 flex flex-wrap gap-1.5 justify-center">
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">Next.js 15</span>
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">TypeScript</span>
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">Supabase Auth</span>
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">PostgreSQL + RLS</span>
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">Server Actions</span>
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">Tailwind CSS</span>
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">Zod</span>
        <span class="px-2.5 py-1 rounded bg-ink-800/60 border border-ink-700/40 text-ink-300 text-[10px] font-mono">Vitest</span>
      </div>

    </div>
  </div>

</Layout>
