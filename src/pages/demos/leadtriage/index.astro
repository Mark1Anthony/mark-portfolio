---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="Lead Triage — Project Details" description="AI-powered lead classification system that reads incoming messages, classifies them by priority, and routes them accordingly.">

  <a href="/mark-portfolio/#work" class="fixed top-6 left-6 z-40 inline-flex items-center gap-2 px-4 py-2 rounded-full backdrop-blur-md bg-black/40 border border-white/10 text-sm text-ink-200 hover:text-accent-cyan hover:border-accent-cyan/40 transition">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    <span data-i18n="back">Back to portfolio</span>
  </a>

  <button id="lang-toggle" class="fixed top-6 right-6 z-40 px-3 py-1.5 rounded-full backdrop-blur-md bg-black/40 border border-white/10 text-sm text-ink-200 hover:text-accent-cyan transition cursor-pointer">EN</button>

  <div class="min-h-screen py-20 px-4 md:px-8">
    <div class="max-w-4xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-14">
        <div class="w-16 h-16 mx-auto rounded-2xl bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-white font-bold text-2xl mb-6">T</div>
        <span class="section-label mx-auto" data-i18n="label">Project</span>
        <h1 class="font-display font-bold text-4xl md:text-5xl mt-4 mb-4" data-i18n="title">Lead Triage</h1>
        <p class="text-ink-400 text-lg max-w-2xl mx-auto" data-i18n="subtitle">
          AI-powered lead classification that reads incoming messages, scores them by priority, and routes them automatically.
        </p>
      </div>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-16">
        <a href="/mark-portfolio/demos/lead-triage/" class="btn-primary text-sm py-3 px-8 inline-flex items-center justify-center gap-2">
          <span data-i18n="cta_demo">Try the demo</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
        </a>
        <a href="https://github.com/Mark1Anthony/lead-triage" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 text-ink-400 text-sm font-medium hover:text-accent-cyan transition py-3 px-8 border border-white/10 rounded-full hover:border-accent-cyan/30">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span data-i18n="cta_code">View source</span>
        </a>
      </div>

      <!-- Why I built this -->
      <div class="glass rounded-2xl p-8 mb-8">
        <h2 class="font-display font-bold text-xl text-ink-50 mb-4" data-i18n="why_title">Why I built this</h2>
        <p class="text-ink-300 text-sm leading-relaxed" data-i18n="why_text">
          Service businesses get inquiries via contact forms but treat them all the same. Some are hot leads ready to buy, others are cold questions. I built a system that reads incoming messages, classifies them by priority using GPT, and routes them accordingly: hot leads get instant notification, warm leads get a follow-up email, cold inquiries go to a nurture list.
        </p>
      </div>

      <!-- What it does -->
      <div class="glass rounded-2xl p-8 mb-8">
        <h2 class="font-display font-bold text-xl text-ink-50 mb-4" data-i18n="what_title">What it does</h2>
        <div class="space-y-4">
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-emerald-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
            </div>
            <div>
              <div class="text-ink-100 text-sm font-semibold" data-i18n="feat_classify_title">AI-powered Lead Classification</div>
              <div class="text-ink-400 text-xs" data-i18n="feat_classify_desc">GPT reads the message, assigns hot, warm, or cold priority based on intent and urgency.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-cyan-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
            </div>
            <div>
              <div class="text-ink-100 text-sm font-semibold" data-i18n="feat_routing_title">Automatic Priority Routing</div>
              <div class="text-ink-400 text-xs" data-i18n="feat_routing_desc">Hot leads get instant notification. Warm leads get a follow-up email. Cold inquiries go to a nurture list.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-violet-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 4.5v15m6-15v15m-10.875 0h15.75c.621 0 1.125-.504 1.125-1.125V5.625c0-.621-.504-1.125-1.125-1.125H4.125C3.504 4.5 3 5.004 3 5.625v12.75c0 .621.504 1.125 1.125 1.125z"/></svg>
            </div>
            <div>
              <div class="text-ink-100 text-sm font-semibold" data-i18n="feat_kanban_title">Kanban Board</div>
              <div class="text-ink-400 text-xs" data-i18n="feat_kanban_desc">Visual lead management board. Drag leads between stages, see priority at a glance.</div>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.348a1.125 1.125 0 010 1.971l-11.54 6.347a1.125 1.125 0 01-1.667-.985V5.653z"/></svg>
            </div>
            <div>
              <div class="text-ink-100 text-sm font-semibold" data-i18n="feat_demo_title">Demo Mode</div>
              <div class="text-ink-400 text-xs" data-i18n="feat_demo_desc">Works without an API key. Submit a test message and see the classification in action.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tech -->
      <div class="glass rounded-2xl p-8 mb-12">
        <h2 class="font-display font-bold text-xl text-ink-50 mb-4" data-i18n="tech_title">Tech decisions</h2>
        <div class="space-y-4 text-sm">
          <div class="flex gap-3"><span class="text-accent-cyan font-mono font-bold w-40 flex-shrink-0">Python</span><span class="text-ink-300" data-i18n="tech_python">Clean, readable backend logic. Easy to extend with new classification rules.</span></div>
          <div class="flex gap-3"><span class="text-accent-cyan font-mono font-bold w-40 flex-shrink-0">FastAPI</span><span class="text-ink-300" data-i18n="tech_fastapi">Async REST API with automatic OpenAPI docs. Type hints throughout.</span></div>
          <div class="flex gap-3"><span class="text-accent-cyan font-mono font-bold w-40 flex-shrink-0">OpenAI API</span><span class="text-ink-300" data-i18n="tech_openai">GPT-powered classification with structured output. Consistent priority scoring.</span></div>
          <div class="flex gap-3"><span class="text-accent-cyan font-mono font-bold w-40 flex-shrink-0">SQLite</span><span class="text-ink-300" data-i18n="tech_sqlite">Lightweight storage for leads and classification history. Zero config needed.</span></div>
          <div class="flex gap-3"><span class="text-accent-cyan font-mono font-bold w-40 flex-shrink-0">Jinja2</span><span class="text-ink-300" data-i18n="tech_jinja">Server-rendered templates for the Kanban board and admin views.</span></div>
        </div>
      </div>

      <!-- Bottom CTA -->
      <div class="text-center">
        <a href="/mark-portfolio/demos/lead-triage/" class="btn-primary text-base py-4 px-10 inline-flex items-center justify-center gap-2">
          <span data-i18n="cta_demo_bottom">Try the demo</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
        </a>
      </div>

    </div>
  </div>

<script>
const t = {
  en: {
    back: 'Back to portfolio',
    label: 'Project',
    title: 'Lead Triage',
    subtitle: 'AI-powered lead classification that reads incoming messages, scores them by priority, and routes them automatically.',
    cta_demo: 'Try the demo',
    cta_code: 'View source',
    why_title: 'Why I built this',
    why_text: "Service businesses get inquiries via contact forms but treat them all the same. Some are hot leads ready to buy, others are cold questions. I built a system that reads incoming messages, classifies them by priority using GPT, and routes them accordingly: hot leads get instant notification, warm leads get a follow-up email, cold inquiries go to a nurture list.",
    what_title: 'What it does',
    feat_classify_title: 'AI-powered Lead Classification',
    feat_classify_desc: 'GPT reads the message, assigns hot, warm, or cold priority based on intent and urgency.',
    feat_routing_title: 'Automatic Priority Routing',
    feat_routing_desc: 'Hot leads get instant notification. Warm leads get a follow-up email. Cold inquiries go to a nurture list.',
    feat_kanban_title: 'Kanban Board',
    feat_kanban_desc: 'Visual lead management board. Drag leads between stages, see priority at a glance.',
    feat_demo_title: 'Demo Mode',
    feat_demo_desc: 'Works without an API key. Submit a test message and see the classification in action.',
    tech_title: 'Tech decisions',
    tech_python: 'Clean, readable backend logic. Easy to extend with new classification rules.',
    tech_fastapi: 'Async REST API with automatic OpenAPI docs. Type hints throughout.',
    tech_openai: 'GPT-powered classification with structured output. Consistent priority scoring.',
    tech_sqlite: 'Lightweight storage for leads and classification history. Zero config needed.',
    tech_jinja: 'Server-rendered templates for the Kanban board and admin views.',
    cta_demo_bottom: 'Try the demo'
  },
  de: {
    back: 'Zum Portfolio',
    label: 'Projekt',
    title: 'Lead Triage',
    subtitle: 'KI-gestützte Lead-Klassifizierung die eingehende Nachrichten liest, nach Priorität bewertet und automatisch weiterleitet.',
    cta_demo: 'Demo ausprobieren',
    cta_code: 'Quellcode ansehen',
    why_title: 'Warum ich das gebaut habe',
    why_text: 'Dienstleistungsunternehmen bekommen Anfragen über Kontaktformulare, behandeln sie aber alle gleich. Manche sind heiße Leads die sofort kaufen wollen, andere sind kalte Fragen. Ich habe ein System gebaut das eingehende Nachrichten liest, sie per GPT nach Priorität klassifiziert und entsprechend weiterleitet: heiße Leads bekommen sofortige Benachrichtigung, warme Leads eine Follow-up-E-Mail, kalte Anfragen gehen auf eine Nurture-Liste.',
    what_title: 'Was es macht',
    feat_classify_title: 'KI-gestützte Lead-Klassifizierung',
    feat_classify_desc: 'GPT liest die Nachricht und weist heiß, warm oder kalt als Priorität zu, basierend auf Absicht und Dringlichkeit.',
    feat_routing_title: 'Automatisches Prioritäts-Routing',
    feat_routing_desc: 'Heiße Leads bekommen sofortige Benachrichtigung. Warme Leads eine Follow-up-E-Mail. Kalte Anfragen gehen auf eine Nurture-Liste.',
    feat_kanban_title: 'Kanban-Board',
    feat_kanban_desc: 'Visuelles Lead-Management-Board. Leads zwischen Stages ziehen, Priorität auf einen Blick sehen.',
    feat_demo_title: 'Demo-Modus',
    feat_demo_desc: 'Funktioniert ohne API-Key. Testnachricht absenden und die Klassifizierung in Aktion sehen.',
    tech_title: 'Technische Entscheidungen',
    tech_python: 'Saubere, lesbare Backend-Logik. Einfach erweiterbar mit neuen Klassifizierungsregeln.',
    tech_fastapi: 'Async REST API mit automatischer OpenAPI-Dokumentation. Type Hints durchgängig.',
    tech_openai: 'GPT-gestützte Klassifizierung mit strukturiertem Output. Konsistente Prioritätsbewertung.',
    tech_sqlite: 'Leichtgewichtige Speicherung für Leads und Klassifizierungshistorie. Keine Konfiguration nötig.',
    tech_jinja: 'Server-gerenderte Templates für das Kanban-Board und Admin-Ansichten.',
    cta_demo_bottom: 'Demo ausprobieren'
  }
};
let lang = localStorage.getItem('lang') || 'en';
function applyLang() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    const val = t[lang]?.[key];
    if (val) el.innerHTML = val;
  });
  document.getElementById('lang-toggle').textContent = lang === 'en' ? 'DE' : 'EN';
}
document.getElementById('lang-toggle').addEventListener('click', () => {
  lang = lang === 'en' ? 'de' : 'en';
  localStorage.setItem('lang', lang);
  applyLang();
});
applyLang();
</script>

</Layout>
